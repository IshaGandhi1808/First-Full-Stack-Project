<div class="header sticky-top bg-body-tertiary">

  <nav
    class="navbar navbar-expand-md bg-body-tertiary border-bottom sticky-top p-3"
  >
    <div class="container-fluid p-0">
      <a href="/listings" class="navbar-brand"
        ><i class="fa-regular fa-compass"></i
      ></a>
      <button
        class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#navbarNavAltMarkup"
        aria-controls="navbarNavAltMarkup"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
        <div class="navbar-nav">
          <a class="nav-link" href="/listings">Explore</a>
          <a class="nav-link" href="/listings/new">Become a host</a>
        </div>

        
        <div class="search-box m-auto d-lg-flex d-none">
          <form class="d-flex w-100" role="search" action="/listings/search">
            <input class="form-control me-2" type="search" placeholder="Search destinations" aria-label="Search" name="location" />
            <button class="btn search-btn d-flex align-items-center gap-1  text-light" type="submit"> <i class="fa-solid fa-magnifying-glass"></i> <span class="d-md-flex d-none fw-semibold"> Search</span></button>
          </form>
        </div>

        <div class="navbar-nav ms-auto">
          <% if (!currUser) { %>
            <a class="nav-link" aria-current="page" href="/signup">Signup</a>
            <a class="nav-link" href="/login">Login</a>
          <% } %>
          <% if (currUser) { %>
            <a class="nav-link" href="/logout">Logout</a>
          <% } %>
        </div>
      </div>
    </div>
  </nav>

  <div class="search-box w-100 d-flex justify-content-center align-items-center py-3 border-bottom d-lg-none">
    <form class="d-flex w-100 px-4" role="search" method="get" action="/listings/search" >
      <input class="form-control me-2" type="search" placeholder="Search destinations" aria-label="Search" name="location" />
      <button class="btn search-btn d-flex align-items-center gap-1 text-light" type="submit"> <i class="fa-solid fa-magnifying-glass"></i> <span class="d-md-flex d-none fw-semibold"> Search</span></button>
    </form>
  </div>
</div>